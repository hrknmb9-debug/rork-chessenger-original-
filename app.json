{
  "expo": {
    "name": "CHESSENGER",
    "slug": "chessenger",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "rork-app",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.CHESSENGER",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "プロフィール写真やタイムライン投稿に使用します",
        "NSPhotoLibraryAddUsageDescription": "写真を保存するために使用します",
        "NSCameraUsageDescription": "プロフィール写真・タイムライン投稿の撮影、およびQRコードスキャンに使用します",
        "NSLocationWhenInUseUsageDescription": "近くのチェス対局相手を探すために位置情報を使用します",
        "UIBackgroundModes": ["remote-notification"]
      },
      "entitlements": {
        "aps-environment": "production"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "app.chessenger",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [{ "scheme": "rork-app" }],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://rork.com/"
        }
      ],
      [
        "expo-notifications",
        {
          "defaultChannel": "default",
          "color": "#8B5CF6"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-camera"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "30e8dzkl5ptrsftnsy7by"
      }
    }
  }
}