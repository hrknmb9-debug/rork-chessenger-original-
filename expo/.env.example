# Supabase（必須）
# https://supabase.com/dashboard でプロジェクト作成後、Settings > API から取得
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_ANON_KEY

# 使い方: このファイルを .env にコピーし、上記の値を実際の Supabase  credentials に置き換えてください
# cp .env.example .env
# 設定後は npx expo start -c でキャッシュクリアして再起動
